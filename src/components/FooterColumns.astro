---
/**
 * FooterColumns.astro
 * -------------------
 * Three-column footer body: tagline + social, quick links, contact.
 */

const { year } = Astro.props as { year?: number };
const currentYear = year ?? new Date().getFullYear();
---

<footer class="sp-footer">
  <div class="sp-footer__inner">

    <div class="sp-footer__col sp-footer__col--about">
      <h2 class="sp-footer__heading">Sean Patrick's Emerald Isle</h2>
      <p class="sp-footer__tagline">A Buffalo landmark since 1966. Join us for great food, cold drinks, and memorable events — from a quiet dinner to a wedding for 230. Family owned and operated.</p>
      <ul class="sp-footer__social" aria-label="Follow us on social media">
        <li>
          <a href="#" class="sp-footer__social-link" aria-label="Facebook">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        </li>
        <li>
          <a href="#" class="sp-footer__social-link" aria-label="Instagram">
            <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
        </li>
        <li>
          <a href="#" class="sp-footer__social-link" aria-label="Twitter / X">
            <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M4 4l16 16M20 4L4 20"/></svg>
          </a>
        </li>
        <li>
          <a href="#" class="sp-footer__social-link" aria-label="YouTube">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.96-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z" fill="currentColor"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="var(--bg-invert)"/></svg>
          </a>
        </li>
      </ul>
    </div>

    <div class="sp-footer__col">
      <h2 class="sp-footer__heading">Quick Links</h2>
      <ul class="sp-footer__links">
        <li><a href="/" class="sp-footer__link">Home</a></li>
        <li><a href="/about" class="sp-footer__link">About Us</a></li>
        <li><a href="/dinner-menu" class="sp-footer__link">Menus</a></li>
        <li><a href="/catering" class="sp-footer__link">Catering</a></li>
        <li><a href="/special-packages" class="sp-footer__link">Special Packages</a></li>
        <li><a href="/gallery" class="sp-footer__link">Gallery</a></li>
        <li><a href="/contact" class="sp-footer__link">Contact Us</a></li>
      </ul>
    </div>

    <div class="sp-footer__col">
      <h2 class="sp-footer__heading">Contact Us</h2>
      <ul class="sp-footer__contact-list">
        <li class="sp-footer__contact-item">
          <svg class="sp-footer__contact-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
          </svg>
          <p class="sp-footer__contact-text">3480 Millersport Highway<br>Getzville, NY 14068</p>
        </li>
        <li class="sp-footer__contact-item">
          <svg class="sp-footer__contact-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.78a16 16 0 0 0 6 6l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16z"/>
          </svg>
          <p class="sp-footer__contact-text">
            <a href="tel:+17166361709">716-636-1709</a><br>
            <a href="tel:+17166365645">716-636-5645 (fax)</a>
          </p>
        </li>
        <li class="sp-footer__contact-item">
          <svg class="sp-footer__contact-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
          </svg>
          <p class="sp-footer__contact-text">
            <a href="mailto:seanpatricks@hotmail.com">seanpatricks@hotmail.com</a>
          </p>
        </li>
      </ul>
    </div>

  </div>

  <div class="sp-footer__bar">
    <p class="sp-footer__copy">
      &copy; <span id="sp-footer-year">{currentYear}</span> Sean Patrick's Emerald Isle. All rights reserved.
      &ensp;·&ensp;<a href="/terms">Terms of Agreement</a>
      &ensp;·&ensp;<a href="#">Privacy Policy</a>
    </p>
  </div>
</footer>
