---
/**
 * BaseLayout.astro
 * ----------------
 * Top-level layout shared by every page in the site. Provides:
 *   - <head> with meta, fonts, external CSS (Leaflet, Google Fonts)
 *   - <Header /> component
 *   - <main> slot
 *   - <Footer /> partial (pre-footer map+hours + footer)
 *   - <script> tags for the global JS bundles
 *
 * Props:
 *   title       string  — page title (defaults to site name)
 *   description string  — meta description (defaults to site tagline)
 *   loadMap     boolean — whether to include the Leaflet map + map.js
 */

import '../styles/system.css';
import '../styles/styles.css';
import '../styles/header.css';
import '../styles/footer.css';
import '../styles/components.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  loadMap?: boolean;
}

const {
  title = "Sean Patrick's Emerald Isle",
  description = "Buffalo wedding venues, banquet halls, great dining and cozy bar. Sean Patrick's restaurant is a warm family environment where you always feel welcome.",
  loadMap = false,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=Lora:wght@400;600&display=swap" rel="stylesheet" />

    {loadMap && (
      <>
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
      </>
    )}
  </head>
  <body>
    <Header />

    <main>
      <slot />
    </main>

    <Footer />

    <!-- Global JS bundles -->
    <script src="/js/nav.js" is:inline></script>
    <script src="/js/site.js" is:inline></script>
    {loadMap && <script src="/js/map.js" is:inline></script>}
  </body>
</html>
