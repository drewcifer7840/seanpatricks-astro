---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MenuPackage from '../../components/MenuPackage.astro';
import { getEntry } from 'astro:content';
import './holiday-mothers-day.css';

const loadMap = true;

const entry = await getEntry('holiday_special', 'holiday-mothers-day');
if (!entry) throw new Error('Missing menu content: src/content/holiday_special/holiday-mothers-day.md');
const { data } = entry;
const title = data.title ?? "Mother's Day Brunch — Sean Patrick's Emerald Isle";
const description = data.summary;
---

<BaseLayout title={title} description={description} loadMap={loadMap}>
  <div class="sp-pkg">
    {data.packages.map((pkg, i) => <MenuPackage pkg={pkg} isFirst={i === 0} compact={pkg.compact} />)}
  </div>
</BaseLayout>
