---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MenuPackage from '../../components/MenuPackage.astro';
import { getEntry } from 'astro:content';
import './banquet-lunch.css';

const loadMap = true;

const entry = await getEntry('banquet_package', 'banquet-lunch');
if (!entry) throw new Error('Missing menu content: src/content/banquet_package/banquet-lunch.md');
const { data } = entry;
const title = data.title ?? "Banquet Lunch — Sean Patrick's Emerald Isle";
const description = data.summary;
---

<BaseLayout title={title} description={description} loadMap={loadMap}>
  <div class="sp-pkg">
    {data.packages.map((pkg, i) => <MenuPackage pkg={pkg} isFirst={i === 0} compact={pkg.compact} />)}
  </div>
</BaseLayout>
