    <li class="sp-gallery__item" data-category="restaurant">
      <figure class="sp-gallery__figure">
        <img src="img/gallery/rest1-1000-400x284.jpg" alt="Restaurant dining room" width="400" height="284" loading="lazy">
      </figure>
      <div class="sp-gallery__caption">
        <span class="sp-gallery__name">Dining Room</span>
        <span class="sp-gallery__divider" aria-hidden="true"></span>
