    <li class="sp-gallery__item" data-category="bar">
      <figure class="sp-gallery__figure">
        <img src="img/gallery/BarTop-400x284.jpg" alt="Bar top seating" width="400" height="284" loading="lazy">
      </figure>
      <div class="sp-gallery__caption">
        <span class="sp-gallery__name">Bar Top</span>
        <span class="sp-gallery__divider" aria-hidden="true"></span>
        <span class="sp-gallery__cat">Bar &amp; Lounge</span>
      </div>
    </li>

    <li class="sp-gallery__item" data-category="bar">
      <figure class="sp-gallery__figure">
        <img src="img/gallery/BarRoom1-400x284.jpg" alt="Bar room" width="400" height="284" loading="lazy">
      </figure>
      <div class="sp-gallery__caption">
        <span class="sp-gallery__name">Bar Room</span>
        <span class="sp-gallery__divider" aria-hidden="true"></span>
        <span class="sp-gallery__cat">Bar &amp; Lounge</span>
      </div>
    </li>

    <li class="sp-gallery__item" data-category="bar">
      <figure class="sp-gallery__figure">
        <img src="img/gallery/bar1-1000-400x284.jpg" alt="Bar seating area" width="400" height="284" loading="lazy">
      </figure>
      <div class="sp-gallery__caption">
        <span class="sp-gallery__name">Bar Seating</span>
        <span class="sp-gallery__divider" aria-hidden="true"></span>
        <span class="sp-gallery__cat">Bar &amp; Lounge</span>
      </div>
    </li>

    <li class="sp-gallery__item" data-category="bar">
      <figure class="sp-gallery__figure">
        <img src="img/gallery/Mainbar-400x284.jpg" alt="Main bar" width="400" height="284" loading="lazy">
      </figure>
      <div class="sp-gallery__caption">
        <span class="sp-gallery__name">Main Bar</span>
        <span class="sp-gallery__divider" aria-hidden="true"></span>
        <span class="sp-gallery__cat">Bar &amp; Lounge</span>
