    <li class="sp-gallery__item" data-category="banquet">
      <figure class="sp-gallery__figure">
        <img src="img/gallery/ban7-1000-400x284.jpg" alt="Banquet hall" width="400" height="284" loading="lazy">
      </figure>
      <div class="sp-gallery__caption">
        <span class="sp-gallery__name">Banquet Hall</span>
        <span class="sp-gallery__divider" aria-hidden="true"></span>
        <span class="sp-gallery__cat">Banquet &amp; Events</span>
      </div>
    </li>

    <li class="sp-gallery__item" data-category="banquet">
      <figure class="sp-gallery__figure">
        <img src="img/gallery/CaitandJustin-400x284.jpg" alt="Wedding reception" width="400" height="284" loading="lazy">
