---
import BaseLayout from '../../layouts/BaseLayout.astro';
import './gallery.css';
const title = "Gallery — Sean Patrick's Emerald Isle";
const description = undefined;
const loadMap = true;
---

<BaseLayout title={title} loadMap={loadMap}>
<section class="sp-gallery" aria-labelledby="gallery-heading">

  <div class="sp-gallery__header">
    <p class="sp-gallery__tagline">Our Space &amp; Cuisine</p>
    <h2 class="sp-gallery__heading" id="gallery-heading">A Taste of Sean Patrick's</h2>
    <p class="sp-gallery__desc">From hearty Buffalo classics to elegant banquet events — take a look at what makes us home.</p>
  </div>

  <div class="sp-gallery__filters" role="group" aria-label="Filter gallery by category">
    <button class="sp-gallery__filter-btn" aria-pressed="true"  data-filter="all">View all</button>
    <button class="sp-gallery__filter-btn" aria-pressed="false" data-filter="food">Food</button>
    <button class="sp-gallery__filter-btn" aria-pressed="false" data-filter="drinks">Drinks</button>
    <button class="sp-gallery__filter-btn" aria-pressed="false" data-filter="bar">Bar &amp; Lounge</button>
    <button class="sp-gallery__filter-btn" aria-pressed="false" data-filter="banquet">Banquet &amp; Events</button>
    <button class="sp-gallery__filter-btn" aria-pressed="false" data-filter="restaurant">Restaurant</button>
  </div>

  <ul class="sp-gallery__grid" id="gallery-grid" aria-live="polite" aria-label="Gallery photos">

    <!-- ── Food ──────────────────────────────────────────────────── -->
    <li class="sp-gallery__item" data-category="food">
      <figure class="sp-gallery__figure">
        <img src="img/gallery/BeefOnWeck-400x284.jpg" alt="Beef on Weck sandwich" width="400" height="284" loading="lazy">
      </figure>
      <div class="sp-gallery__caption">
        <span class="sp-gallery__name">Beef on Weck</span>
        <span class="sp-gallery__divider" aria-hidden="true"></span>
        <span class="sp-gallery__cat">Food</span>
      </div>
    </li>

    <li class="sp-gallery__item" data-category="food">
      <figure class="sp-gallery__figure">
        <img src="img/gallery/NYStrip-400x284.jpg" alt="NY Strip steak" width="400" height="284" loading="lazy">
      </figure>
      <div class="sp-gallery__caption">
        <span class="sp-gallery__name">NY Strip</span>
        <span class="sp-gallery__divider" aria-hidden="true"></span>
        <span class="sp-gallery__cat">Food</span>
      </div>
    </li>

    <li class="sp-gallery__item" data-category="food">
      <figure class="sp-gallery__figure">
        <img src="img/gallery/Shrimp_SalmonScampi-400x284.jpg" alt="Shrimp and salmon scampi" width="400" height="284" loading="lazy">
      </figure>
      <div class="sp-gallery__caption">
        <span class="sp-gallery__name">Shrimp &amp; Salmon Scampi</span>
        <span class="sp-gallery__divider" aria-hidden="true"></span>
        <span class="sp-gallery__cat">Food</span>
      </div>
    </li>

    <li class="sp-gallery__item" data-category="food">
      <figure class="sp-gallery__figure">
        <img src="img/gallery/ChickenParm-400x284.jpg" alt="Chicken parmesan" width="400" height="284" loading="lazy">
      </figure>
      <div class="sp-gallery__caption">
        <span class="sp-gallery__name">Chicken Parm</span>
        <span class="sp-gallery__divider" aria-hidden="true"></span>
        <span class="sp-gallery__cat">Food</span>
      </div>
    </li>

    <li class="sp-gallery__item" data-category="food">
      <figure class="sp-gallery__figure">
        <img src="img/gallery/ClassicBurger-400x284.jpg" alt="Classic burger" width="400" height="284" loading="lazy">
      </figure>
      <div class="sp-gallery__caption">
        <span class="sp-gallery__name">Classic Burger</span>
        <span class="sp-gallery__divider" aria-hidden="true"></span>
        <span class="sp-gallery__cat">Food</span>
      </div>
    </li>

    <li class="sp-gallery__item" data-category="food">
      <figure class="sp-gallery__figure">
        <img src="img/gallery/BBFishFry-400x284.jpg" alt="Fish fry" width="400" height="284" loading="lazy">
      </figure>
      <div class="sp-gallery__caption">
        <span class="sp-gallery__name">Friday Fish Fry</span>
        <span class="sp-gallery__divider" aria-hidden="true"></span>
        <span class="sp-gallery__cat">Food</span>
      </div>
    </li>

    <li class="sp-gallery__item" data-category="food">
      <figure class="sp-gallery__figure">
        <img src="img/gallery/CrabCakeDinner-400x284.jpg" alt="Crab cake dinner" width="400" height="284" loading="lazy">
      </figure>
      <div class="sp-gallery__caption">
        <span class="sp-gallery__name">Crab Cake Dinner</span>
        <span class="sp-gallery__divider" aria-hidden="true"></span>
        <span class="sp-gallery__cat">Food</span>
      </div>
    </li>

    <li class="sp-gallery__item" data-category="food">
      <figure class="sp-gallery__figure">
        <img src="img/gallery/SignatureSalad-400x284.jpg" alt="Signature salad" width="400" height="284" loading="lazy">
      </figure>
      <div class="sp-gallery__caption">
        <span class="sp-gallery__name">Signature Salad</span>
        <span class="sp-gallery__divider" aria-hidden="true"></span>
        <span class="sp-gallery__cat">Food</span>
      </div>
    </li>

    <li class="sp-gallery__item" data-category="food">
      <figure class="sp-gallery__figure">
        <img src="img/gallery/MozzarellaFlatBread-400x284.jpg" alt="Mozzarella flatbread" width="400" height="284" loading="lazy">
      </figure>
      <div class="sp-gallery__caption">
        <span class="sp-gallery__name">Mozzarella Flatbread</span>
        <span class="sp-gallery__divider" aria-hidden="true"></span>
        <span class="sp-gallery__cat">Food</span>
      </div>
    </li>

    <!-- ── Drinks ─────────────────────────────────────────────────── -->
    <li class="sp-gallery__item" data-category="drinks">
      <figure class="sp-gallery__figure">
        <img src="img/gallery/Martinis2-400x284.jpg" alt="Martini cocktails" width="400" height="284" loading="lazy">
      </figure>
      <div class="sp-gallery__caption">
        <span class="sp-gallery__name">Martinis</span>
        <span class="sp-gallery__divider" aria-hidden="true"></span>
        <span class="sp-gallery__cat">Drinks</span>
      </div>
    </li>

    <li class="sp-gallery__item" data-category="drinks">
      <figure class="sp-gallery__figure">
        <img src="img/gallery/Martinis3-400x284.jpg" alt="Signature cocktails" width="400" height="284" loading="lazy">
      </figure>
      <div class="sp-gallery__caption">
        <span class="sp-gallery__name">Signature Cocktails</span>
        <span class="sp-gallery__divider" aria-hidden="true"></span>
        <span class="sp-gallery__cat">Drinks</span>
      </div>
    </li>

    <li class="sp-gallery__item" data-category="drinks">
      <figure class="sp-gallery__figure">
        <img src="img/gallery/Taps-400x284.jpg" alt="Draft beer taps" width="400" height="284" loading="lazy">
      </figure>
      <div class="sp-gallery__caption">
        <span class="sp-gallery__name">Draft Taps</span>
        <span class="sp-gallery__divider" aria-hidden="true"></span>
        <span class="sp-gallery__cat">Drinks</span>
