    </li>

    <!-- ── Banquet & Events ───────────────────────────────────────── -->
    <li class="sp-gallery__item" data-category="banquet">
      <figure class="sp-gallery__figure">
        <img src="img/gallery/ban1-1000-400x284.jpg" alt="Banquet room setup" width="400" height="284" loading="lazy">
      </figure>
      <div class="sp-gallery__caption">
        <span class="sp-gallery__name">Banquet Room</span>
        <span class="sp-gallery__divider" aria-hidden="true"></span>
        <span class="sp-gallery__cat">Banquet &amp; Events</span>
      </div>
    </li>

    <li class="sp-gallery__item" data-category="banquet">
      <figure class="sp-gallery__figure">
        <img src="img/gallery/ban2-1000-400x284.jpg" alt="Banquet dining setup" width="400" height="284" loading="lazy">
