        <span class="sp-gallery__divider" aria-hidden="true"></span>
        <span class="sp-gallery__cat">Banquet &amp; Events</span>
      </div>
    </li>

    <li class="sp-gallery__item" data-category="banquet">
      <figure class="sp-gallery__figure">
        <img src="img/gallery/BarPartySetUp2-400x284.jpg" alt="Party setup at the bar" width="400" height="284" loading="lazy">
      </figure>
      <div class="sp-gallery__caption">
        <span class="sp-gallery__name">Party Setup</span>
        <span class="sp-gallery__divider" aria-hidden="true"></span>
        <span class="sp-gallery__cat">Banquet &amp; Events</span>
      </div>
    </li>

    <li class="sp-gallery__item" data-category="banquet">
      <figure class="sp-gallery__figure">
        <img src="img/gallery/ban10-1000-400x284.jpg" alt="Banquet table setting" width="400" height="284" loading="lazy">
      </figure>
      <div class="sp-gallery__caption">
        <span class="sp-gallery__name">Table Setting</span>
        <span class="sp-gallery__divider" aria-hidden="true"></span>
        <span class="sp-gallery__cat">Banquet &amp; Events</span>
      </div>
    </li>

    <li class="sp-gallery__item" data-category="banquet">
      <figure class="sp-gallery__figure">
        <img src="img/gallery/CoveredBanquetEntrance-400x284.jpg" alt="Covered banquet entrance" width="400" height="284" loading="lazy">
      </figure>
      <div class="sp-gallery__caption">
        <span class="sp-gallery__name">Banquet Entrance</span>
        <span class="sp-gallery__divider" aria-hidden="true"></span>
        <span class="sp-gallery__cat">Banquet &amp; Events</span>
