    </li>

    <!-- ── Restaurant & Exterior ──────────────────────────────────── -->
    <li class="sp-gallery__item" data-category="restaurant">
      <figure class="sp-gallery__figure">
        <img src="img/gallery/Exterior1-400x284.jpg" alt="Restaurant exterior" width="400" height="284" loading="lazy">
