---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MenuPackage from '../../components/MenuPackage.astro';
import { getEntry } from 'astro:content';
import './holiday-easter.css';

const title = "Easter Dinner Buffet — Sean Patrick's Emerald Isle";
const description = "Join us for our Easter Dinner Buffet at Sean Patrick";
const loadMap = true;

const entry = await getEntry('menus', 'holiday-easter');
if (!entry) throw new Error('Missing menu content: src/content/menus/holiday-easter.md');
const { data } = entry;
---

<BaseLayout title={title} description={description} loadMap={loadMap}>
  <div class="sp-pkg">
    {data.packages.map((pkg, i) => <MenuPackage pkg={pkg} isFirst={i === 0} compact={pkg.compact} />)}
  </div>
</BaseLayout>
