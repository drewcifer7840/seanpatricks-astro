---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MenuPackage from '../../components/MenuPackage.astro';
import { getEntry } from 'astro:content';
import './banquet-beverage.css';

const title = "Beverage Services — Sean Patrick's Emerald Isle";
const description = undefined;
const loadMap = true;

const entry = await getEntry('menus', 'banquet-beverage');
if (!entry) throw new Error('Missing menu content: src/content/menus/banquet-beverage.md');
const { data } = entry;
---

<BaseLayout title={title} loadMap={loadMap}>
  <div class="sp-pkg">
    {data.packages.map((pkg, i) => <MenuPackage pkg={pkg} isFirst={i === 0} compact={pkg.compact} />)}
  </div>
</BaseLayout>
